# Access runtime files
*.laccdb
*.ldb

# Compiled / distribution files
*.accde

# Temporary / backup files
*.tmp
*.bak
*.old

# Windows junk
Thumbs.db
Desktop.ini

# VS Code
.vscode/

# Python (if used)
__pycache__/
*.pyc
.env

# Local config (machine-specific paths)
config.local.json

# Logs / debug outputs
*.log

